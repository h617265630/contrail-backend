# Backend Environment Configuration
# Copy this file to .env and fill in your values
# DO NOT commit .env to git (it's in .gitignore)

# ── API Keys ────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...                    # GitHub API token for repository search
TAVILY_API_KEY=tvly-...               # Tavily search API key
YOUTUBE_API_KEY=...                    # YouTube Data API v3 key (optional)
MINIMAX_API_KEY=...                   # MiniMax API key (optional)
MINIMAX_BASE_URL=https://api.minimax.chat  # MiniMax API base URL (optional)

# ── LLM Models ──────────────────────────────────────────────────────────────
MODEL_INTENT=gpt-4o-mini              # Model for intent detection
MODEL_PLANNER=gpt-4o                  # Model for learning path planning
MODEL_GENERATOR=gpt-4.1               # Model for content generation

# ── Database ──────────────────────────────────────────────────────────────────
# Railway automatically sets DATABASE_URL in production
# For local development with Supabase:
# DATABASE_URL=postgresql://postgres:[password]@[host]:[port]/[database]
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/path

# ── Application ───────────────────────────────────────────────────────────────
SQL_ECHO=false                        # Log SQL queries (debug only)
APP_DEBUG=false                        # Enable debug mode (production: false)

# ── Security ─────────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-here         # JWT secret key (generate a random one)
ALGORITHM=HS256                        # JWT algorithm
ACCESS_TOKEN_EXPIRE_MINUTES=30          # Token expiration time

# ── LLM Provider ──────────────────────────────────────────────────────────────
LLM_PROVIDER=openai           # openai | minimax
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini      # optional, default gpt-4o-mini

# MiniMax Token Plan (推荐)
# 订阅地址: https://platform.minimaxi.com/subscribe/token-plan
MINIMAX_API_KEY=你的Token_Plan_API_Key
MINIMAX_MODEL=MiniMax-M2.7  # MiniMax-M2.7 | MiniMax-M2.7-highspeed

# ── Search Provider ────────────────────────────────────────────────────────────
SEARCH_PROVIDER=tavily        # tavily | serper
TAVILY_API_KEY=tvly-...

# Serper (optional alternative)
# SERPER_API_KEY=...
